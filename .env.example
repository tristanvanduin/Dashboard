# =====================================================================================
# Voorbeeld-omgevingsvariabelen voor het Dashboard.
#
# Kopieer dit bestand naar .env.local (lokaal) of zet de waarden in je host
# (bijv. Vercel: Settings -> Environment Variables) en deploy opnieuw. .env.local staat
# in .gitignore en hoort NOOIT gecommit te worden. Vul echte waarden nooit in dit bestand in.
#
# OMSCHAKELEN NAAR EEN ANDERE SUPABASE: alleen de drie SUPABASE-waarden hieronder wijzen
# naar de database. De Google Ads-, Meta- en LinkedIn-koppelingen staan daar los van en
# blijven ongewijzigd; de sync schrijft simpelweg naar de Supabase waar deze URL naar wijst.
# =====================================================================================

# ── Supabase (verplicht) ─────────────────────────────────────────────────────────────
# URL en anon-key staan in Project Settings -> API. De service-role-key is server-only en
# omzeilt RLS: nooit naar de client sturen, nooit in NEXT_PUBLIC_ zetten.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Server-side fallback voor de URL (scripts/seed-first-admin.mjs, lib/supabase-admin.ts).
# Laat leeg om NEXT_PUBLIC_SUPABASE_URL te hergebruiken, of zet dezelfde project-URL.
SUPABASE_URL=

# ── Google Ads (databron) ────────────────────────────────────────────────────────────
# Refresh-token genereer je eenmalig met scripts/get-refresh-token.ts (leest CLIENT_ID/SECRET).
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_MANAGER_CUSTOMER_ID=
GOOGLE_ADS_REFRESH_TOKEN=

# ── Google Merchant Center (optioneel; product-feed-verrijking) ───────────────────────
GOOGLE_MERCHANT_ACCOUNT_ID=
GOOGLE_MERCHANT_FEED_LABEL=
GOOGLE_MERCHANT_CONTENT_LANGUAGE=
GOOGLE_MERCHANT_CHANNEL=

# ── Meta (Facebook) Ads (optioneel; M-sporen) ─────────────────────────────────────────
META_ADS_APP_ID=
META_ADS_APP_SECRET=
META_ADS_ACCESS_TOKEN=
META_VISION_MODEL=

# ── LinkedIn Ads (optioneel; L-sporen) ────────────────────────────────────────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REFRESH_TOKEN=

# ── LLM (verplicht voor analyses) ─────────────────────────────────────────────────────
# De app praat via het OpenAI-compatibele chat-completions-formaat. Default endpoint is de
# directe Gemini-API; zet daarvoor GEMINI_API_KEY. De modellen staan in lib/analysis/llm-router.ts
# (MODEL_CATALOG), nu gemini-3-flash-preview c.s.
GEMINI_API_KEY=
# Optioneel: terug naar OpenRouter of een andere OpenAI-compatibele provider. Zet dan ook de
# model-ID's in MODEL_CATALOG om. Leeg = de directe Gemini-endpoint.
# LLM_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=

# ── Auth / O1 (rollen en RLS) ─────────────────────────────────────────────────────────
# Laat O1_AUTH_ENFORCED leeg of 'false' zolang de auth-laag niet live is (pass-through).
# Zet op 'true' samen met migratie 001 + 017 en de eerste admin-seed.
O1_AUTH_ENFORCED=
# E-mail van de eerste admin voor scripts/seed-first-admin.mjs.
SEED_ADMIN_EMAIL=

# ── Cron / scheduler ──────────────────────────────────────────────────────────────────
# Gedeeld geheim dat de cron-routes en de backup-workflow beschermt.
CRON_SECRET=

# ── Observability / alerting (optioneel) ──────────────────────────────────────────────
SENTRY_DSN=
SLACK_WEBHOOK_URL=
# LOG_LEVEL: debug | info | warn | error (default info).
LOG_LEVEL=
